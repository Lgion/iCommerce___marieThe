// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum AppType {
  ECOMMERCE
  SERVICES
  BOTH
}

enum CertificateType {
  CV
  CERTIFICATE
  DIPLOMA
  FORMATION
}

model User {
  id       String    @id @default(uuid())
  clerkId  String    @unique // ID de l'utilisateur Clerk (obligatoire)
  email    String    @unique
  appType  AppType?  // Type d'application choisi
  isSetup  Boolean   @default(false) // A terminé l'onboarding
  isOwner  Boolean   @default(false) // Est le propriétaire de l'app
  // password supprimé - authentification gérée par Clerk
  shops    Shop[]
  orders   Order[]   // Commandes passées par cet utilisateur
  bookedSlots ServiceSlot[] @relation("UserBookedSlots") // Créneaux réservés par cet utilisateur
  serviceDetails ServiceDetails?
  services Service[]  // Services offerts par ce prestataire
  comments Comment[] // Commentaires laissés par cet utilisateur
  dashboardSessions DashboardSession[] // Sessions dashboard
  promotions Promotion[] // Promotions créées
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shop {
  id          String    @id @default(uuid())
  name        String
  description String?
  owner       User      @relation(fields: [ownerId], references: [id])
  ownerId     String
  type        Int       @default(0)
  products    Product[]
  services    Service[]
}

model Product {
  id            String      @id @default(uuid())
  title         String
  description   String
  price         Float
  imageUrl      String?
  imagePublicId String?     // Cloudinary public_id
  imageFolder   String?     // Cloudinary folder path
  variations    Variation[]
  orderItems    OrderItem[]
  digitalFile   String?     // Pour produits numériques
  shop          Shop        @relation(fields: [shopId], references: [id])
  shopId        String
}

model Variation {
  id        String             @id @default(uuid())
  name      String
  options   VariationOption[]
  product   Product            @relation(fields: [productId], references: [id])
  productId String
}

model VariationOption {
  id          String     @id @default(uuid())
  value       String
  variation   Variation  @relation(fields: [variationId], references: [id])
  variationId String
}

model ServiceSlot {
  id         String   @id @default(uuid())
  startTime  DateTime
  endTime    DateTime
  isBooked   Boolean  @default(false)
  service    Service  @relation(fields: [serviceId], references: [id])
  serviceId  String
  orderItem  OrderItem? @relation(fields: [orderItemId], references: [id])
  orderItemId String?
  bookedBy   User?    @relation("UserBookedSlots", fields: [bookedById], references: [id])
  bookedById String?
  bookedAt   DateTime? // Quand la réservation a été faite
}

model Order {
  id         String      @id @default(uuid())
  items      OrderItem[]
  total      Float
  status     OrderStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  user       User        @relation(fields: [userId], references: [id])
  userId     String
  promotion  Promotion?  @relation(fields: [promotionId], references: [id])
  promotionId String?
}

model OrderItem {
  id          String       @id @default(uuid())
  product     Product      @relation(fields: [productId], references: [id])
  productId   String
  variation   String?      // Option sélectionnée
  serviceSlots ServiceSlot[] // Relation one-to-many pour les réservations multi-slot
  quantity    Int
  price       Float
  order       Order        @relation(fields: [orderId], references: [id])
  orderId     String
}

// Modèles pour le système de services
model ServiceDetails {
  id            String          @id @default(uuid())
  videoUrl      String?         // Lien YouTube
  imageUrl      String?         // Lien vers l'image de profil
  imagePublicId String?         // Cloudinary public_id
  imageFolder   String?         // Cloudinary folder path
  firstName     String
  lastName      String
  pseudo        String
  slogan        String?
  description   String?         // Bio/description
  category      ServiceCategory @relation(fields: [categoryId], references: [id])
  categoryId    String
  user          User            @relation(fields: [userId], references: [id])
  userId        String          @unique
  cvCertificates CvCertificate[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model ServiceCategory {
  id            String           @id @default(uuid())
  name          String           @unique
  description   String?
  serviceDetails ServiceDetails[]
  services      Service[]
  createdAt     DateTime         @default(now())
}

model CvCertificate {
  id              String         @id @default(uuid())
  title           String
  description     String
  type            CertificateType @default(CV)
  serviceDetails  ServiceDetails @relation(fields: [serviceDetailsId], references: [id])
  serviceDetailsId String
  createdAt       DateTime       @default(now())
}

model Comment {
  id        String   @id @default(uuid())
  text      String
  rating    Int?     // Note sur 5 étoiles (facultatif)
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  service   Service  @relation(fields: [serviceId], references: [id])
  serviceId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id            String          @id @default(uuid())
  name          String
  description   String
  imageUrl      String?
  imagePublicId String?         // Cloudinary public_id
  imageFolder   String?         // Cloudinary folder path
  type          String          // Ex: nattes, tresses, frange pour coiffure
  prixHoraire   Float           // Prix par heure
  durations     ServiceDuration[] // Durées possibles
  slots         ServiceSlot[]   // Créneaux de réservation
  category    ServiceCategory @relation(fields: [categoryId], references: [id])
  categoryId  String
  provider    User            @relation(fields: [providerId], references: [id])
  providerId  String
  shop        Shop?           @relation(fields: [shopId], references: [id])
  shopId      String?
  comments    Comment[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ServiceDuration {
  id        String  @id @default(uuid())
  minutes   Int     // Durée en minutes (30, 45, 60, etc.)
  service   Service @relation(fields: [serviceId], references: [id])
  serviceId String
}

// ============================================
// MODÈLES DASHBOARD ADMINISTRATION
// ============================================

// Historique des connexions au dashboard
model DashboardSession {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  loginAt   DateTime @default(now())
  logoutAt  DateTime?
  ipAddress String?
  userAgent String?
  duration  Int?     // Durée en secondes
  actions   DashboardAction[] // Actions effectuées pendant la session
  
  @@index([userId, loginAt])
}

// Log des actions sensibles dans le dashboard
model DashboardAction {
  id          String           @id @default(uuid())
  session     DashboardSession @relation(fields: [sessionId], references: [id])
  sessionId   String
  action      String           // CREATE, UPDATE, DELETE, EXPORT, VIEW
  entityType  String           // PRODUCT, SERVICE, SLOT, PROMOTION, USER, etc.
  entityId    String?
  details     String?          // JSON avec détails de l'action
  createdAt   DateTime         @default(now())
  
  @@index([sessionId, createdAt])
  @@index([entityType, entityId])
}

// Promotions et réductions
model Promotion {
  id          String    @id @default(uuid())
  code        String    @unique
  description String
  type        String    // PERCENTAGE, FIXED_AMOUNT, FREE_SHIPPING
  value       Float     // Pourcentage ou montant fixe
  minAmount   Float?    // Montant minimum de commande
  maxUses     Int?      // Nombre maximum d'utilisations
  usedCount   Int       @default(0)
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean   @default(true)
  
  // Ciblage
  targetType  String?   // PRODUCT, SERVICE, CATEGORY, ALL
  targetId    String?   // ID de l'entité ciblée
  
  // Relations
  createdBy   User      @relation(fields: [userId], references: [id])
  userId      String
  orders      Order[]   // Commandes utilisant cette promotion
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([code, isActive])
  @@index([startDate, endDate])
}

// Analytics - métriques agrégées pour performance
model Analytics {
  id            String   @id @default(uuid())
  date          DateTime @default(now())
  metric        String   // REVENUE, BOOKINGS_COUNT, PRODUCTS_SOLD, NEW_USERS, etc.
  value         Float
  metadata      String?  // JSON pour données supplémentaires
  
  // Granularité
  period        String   // HOUR, DAY, WEEK, MONTH, YEAR
  entityType    String?  // PRODUCT, SERVICE, SHOP, CATEGORY, USER
  entityId      String?
  
  createdAt     DateTime @default(now())
  
  @@index([date, metric, period])
  @@index([entityType, entityId])
  @@index([metric, period, date])
}
